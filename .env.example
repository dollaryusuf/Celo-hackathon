# ==========================================
# AEGIS: ENVIRONMENT CONFIGURATION
# ==========================================

# [ AI ENGINE ]
# Primary authentication key for the Gemini intelligence engine.
# Required for natural language processing and autonomous tool execution.
GEMINI_API_KEY="your_gemini_api_key_here"

# [ APPLICATION ROUTING ]
# The absolute base URL where the Aegis application is deployed.
# Required for CORS configuration, API route resolution, and Webhook callbacks.
# Use http://localhost:3000 for local development.
APP_URL="http://localhost:3000"